# Runtime data — never track generated outputs, uploads, state, or logs
outputs/
uploads/
archives/
state/
logs/
accounts/
certs/

# Re-include portal/state/scripts/ so safe_restart.sh and friends ship with the repo
!portal/state/
portal/state/*
!portal/state/scripts/
!portal/state/scripts/**

# Secrets and local configs
*.seedance
*.nanobanana
*.env
volcengine-portrait/config.json

# Dreamina account session data (contains tokens)
.dreamina_cli/

# Local debug / signing-experiment scripts (may embed AK/SK or absolute desktop paths)
volcengine-portrait/debug_sig.py
volcengine-portrait/_cmp_sig.py
debug_*.py
_cmp_*.py

