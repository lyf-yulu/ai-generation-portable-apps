.DS_Store
__pycache__/
*.pyc
.venv/
.portable_python/
.superpowers/

# Runtime data — never track generated outputs, uploads, state, or logs
# 无 / 后缀 = 目录/文件/symlink 都覆盖（deploy.sh 把 25GB 数据挂成 symlink 时会用到）
outputs
uploads
archives
state
logs
accounts
certs

# Re-include portal/state/scripts/ so safe_restart.sh and friends ship with the repo
!portal/state/
portal/state/*
!portal/state/scripts/
!portal/state/scripts/**

# Secrets and local configs
*.seedance
*.nanobanana
*.env
volcengine-portrait/config.json

# Dreamina account session data (contains tokens)
.dreamina_cli/

# Local debug / signing-experiment scripts (may embed AK/SK or absolute desktop paths)
volcengine-portrait/debug_sig.py
volcengine-portrait/_cmp_sig.py
debug_*.py
_cmp_*.py

# Runtime / archive folders that occasionally land at the repo root
.coordination/
portal/.launcher_pid.json
# 启动器本地备份（升级时自动生成）
启动器.command.bak*
docs/drafts/
docs/superpowers/
docs/FACT_AUDIT.md
docs/pending-fixes.md

